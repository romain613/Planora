    setBpLoading(true);
    api("/api/pages?companyId=" + company.id).then(d => { if (Array.isArray(d)) setBpPages(d); }).finally(() => setBpLoading(false));
  }, [company?.id, tab]);

  // Auto-save (3s debounce, only for existing forms in builder view)
  useEffect(() => {
    if (!selForm || formView !== "builder" || !fbName.trim()) return;
    if (fbAutoSaveTimer.current) clearTimeout(fbAutoSaveTimer.current);
    fbAutoSaveTimer.current = setTimeout(async () => {
      const slug = fbName.toLowerCase().replace(/[^a-z0-9]+/g,'-').replace(/(^-|-$)/g,'');
      const flatFields = fbPages.flat();
      const pageIds = fbPages.map(p => p.map(f => f.id));
      const settings = { btnText:fbBtnText, btnColor:fbBtnColor, thankTitle:fbThankTitle, thankMsg:fbThankMsg, showLogo:fbShowLogo, pages:pageIds };
      const payload = { name:fbName, slug, description:fbDesc, color:fbColor, fields:flatFields, calendarId:fbCalId||null, settings };
      const up = await api(`/api/forms/${selForm.id}`, {method:"PUT", body:payload});
      if (up?.id) { setForms(prev => prev.map(f => f.id===up.id ? up : f)); setFbLastSaved(new Date()); }
    }, 3000);
    return () => { if (fbAutoSaveTimer.current) clearTimeout(fbAutoSaveTimer.current); };
  }, [fbName, fbDesc, fbColor, fbBtnText, fbBtnColor, fbThankTitle, fbThankMsg, fbShowLogo, fbPages, fbCalId]);

  // Google Integrations state
