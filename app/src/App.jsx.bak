  const [chatFloating, setChatFloating] = useState(false);
  const [chatMinimized, setChatMinimized] = useState(false);
  const [chatUnreadCount, setChatUnreadCount] = useState(0);
  // Agenda general state
  const [agendaWeekOffset, setAgendaWeekOffset] = useState(0);
  const [agendaFilterCals, setAgendaFilterCals] = useState([]);
  const [agendaFilterCollabs, setAgendaFilterCollabs] = useState([]);
  const [agendaFilterStatus, setAgendaFilterStatus] = useState([]);
  const [agendaShowFilters, setAgendaShowFilters] = useState(false);
