  const [settingsCompanyName, setSettingsCompanyName] = useState("");
  const [settingsCompanySlug, setSettingsCompanySlug] = useState("");
  const [settingsCompanyDomain, setSettingsCompanyDomain] = useState("");
  const [settingsCompanyAddress, setSettingsCompanyAddress] = useState("");
  const [settingsShowLogo, setSettingsShowLogo] = useState(true);
  const [settingsPoweredBy, setSettingsPoweredBy] = useState(false);
  const [settingsAutoDelete90, setSettingsAutoDelete90] = useState(false);

  // Load settings when company changes
  useEffect(() => {
    if (!company?.id) return;
    // Init company fields
    setSettingsCompanyName(company.name || "");
    setSettingsCompanySlug(company.slug || "");
    setSettingsCompanyDomain(company.domain || "");
    setSettingsCompanyAddress(company.address || "");
    api("/api/settings?companyId=" + company.id).then(s => {
      if (!s) return;
      setSettingsTimezone(s.timezone || "Europe/Paris");
      setSettingsLanguage(s.language || "fr");
      setSettingsCancelPolicy(s.cancelPolicy || "");
      setSettingsCustomDomain(s.customDomain || "");
      setSettingsBrandColor(s.brandColor || "#2563EB");
      setChatWebhook(s.google_chat_webhook || "");
      setGa4PropertyId(s.ga4_property_id || "");
      setGoogleTasksAuto(s.google_tasks_auto !== false);
      setReminder24h(!!s.reminder24h);
      setReminder1h(!!s.reminder1h);
      setReminder15min(!!s.reminder15min);
      setReminderSms(!!s.reminderSms);
      setSettingsMaxAdvanceDays(s.maxAdvanceDays ?? 60);
      setSettingsShowLogo(s.showLogo !== false);
      setSettingsPoweredBy(!!s.poweredBy);
      setSettingsAutoDelete90(!!s.autoDelete90);
