  const [smsGlobalLoading, setSmsGlobalLoading] = useState(false);
  // Revenue stats
  const [revenueStats, setRevenueStats] = useState(null);
  const [smsBulkCompany, setSmsBulkCompany] = useState("");
  const [smsBulkAmount, setSmsBulkAmount] = useState("");
  const [smsBulkMode, setSmsBulkMode] = useState("add"); // add | set
  useEffect(()=>{ if(isSupraAdmin && tab==="vision") api("/api/init?companyId="+company.id).then(d=>{ if(d?.allSmsCredits) setCompanySmsCredits(d.allSmsCredits); if(d?.allCalendars) setAllCalendars(d.allCalendars); if(d?.allBookings) setAllBookings(d.allBookings); if(d?.allContacts) setAllContacts(d.allContacts); if(d?.allUsers) setAllUsers(d.allUsers); if(d?.allCompanies) setAllCompanies(d.allCompanies); if(d?.allPhoneNumbers) setAllPhoneNumbers(d.allPhoneNumbers); if(d?.phonePlans) setPhonePlans(d.phonePlans); if(d?.voipPacks) setVoipPacks(d.voipPacks); if(d?.smsPacks) setSmsPacks(d.smsPacks); if(d?.allTelecomCredits && typeof d.allTelecomCredits==='object') setAllTelecomCredits(d.allTelecomCredits); if(d?.telecomCreditLogs) setTelecomCreditLogs(d.telecomCreditLogs); }); },[tab]);
  useEffect(()=>{ if(isSupraAdmin && tab==="vision" && visionSubTab==="sms") { setSmsGlobalLoading(true); api("/api/sms/global-stats").then(d=>{ if(d) setSmsGlobalStats(d); setSmsGlobalLoading(false); }); } },[tab,visionSubTab]);
  // Load tickets for company
  useEffect(()=>{ if(company?.id) api(`/api/tickets?companyId=${company.id}`).then(r=>{ if(r?.tickets) setTickets(r.tickets); }); },[company?.id]);
  // Load supra ticket count for badge
  useEffect(()=>{ if(isSupraAdmin) api("/api/tickets/open-count").then(r=>{ if(r?.count!==undefined) setOpenTicketCount(r.count); }); },[]);
  // Load supra tickets when viewing tab
  useEffect(()=>{ if(isSupraAdmin && visionSubTab==="tickets" && tab==="vision") { api("/api/tickets/all").then(r=>{ if(r?.tickets) setSupraTickets(r.tickets); }); api("/api/tickets/stats").then(r=>{ if(r) setSupraTicketStats(r); }); } },[visionSubTab, tab]);
  // Load revenue stats
  useEffect(()=>{ if(company?.id){ const p=revenueStats?._period||'month'; const f=revenueStats?._from||''; const t=revenueStats?._to||''; let url=`/api/data/revenue-stats?companyId=${company.id}&period=${p}`; if(p==='custom'&&f&&t) url+=`&from=${f}&to=${t}`; api(url).then(r=>{ if(r && !r.error) setRevenueStats(prev=>({...r,_period:prev?._period||'month',_from:prev?._from||'',_to:prev?._to||''})); }); } },[company?.id]);
  // ── Chat emoji categories ──
  const ADMIN_CHAT_EMOJIS = { "Smileys":["😀","😂","🤣","😊","😍","🥰","😘","😎","🤩","🥳","😅","😢","😤","🤔","😴","🤗","😇","🙄","😬","🤯","💀","🫠","🤭","😏"],"Gestes":["👍","👎","👏","🤝","✌️","🤞","💪","🙏","👋","🫶","❤️","🔥","⭐","💯","✅","❌","🎉","🎊","💬","📌","📎","🗓️","⏰","🏆"] };
  const ADMIN_REACTION_EMOJIS = ["👍","❤️","😂","😮","😢","🔥","🎉","👏"];

  // Load chat messages on mount
  const loadChatMessages = () => {
    if (!company?.id) return;
    const sender = collabs[0];
    const params = chatMode === "dm" && chatDmTarget
      ? `companyId=${company.id}&limit=50&senderId=${sender?.id}&recipientId=${chatDmTarget.id}`
      : `companyId=${company.id}&limit=50`;
    api(`/api/messaging?${params}`).then(r => {
      if (r?.messages) { setChatMessages(r.messages); setTimeout(() => chatEndRef.current?.scrollIntoView({ behavior: "auto" }), 100); }
    });
  };
  useEffect(() => { loadChatMessages(); }, [company?.id, chatMode, chatDmTarget?.id]);

  // Chat: heartbeat for online status (every 10s)
  useEffect(() => {
    if (!company?.id || !collabs[0]?.id) return;
    const beat = () => api("/api/messaging/heartbeat", { method: "POST", body: { collaboratorId: collabs[0].id, companyId: company.id } });
    beat();
    const interval = setInterval(beat, 10000);
    return () => clearInterval(interval);
  }, [company?.id, collabs[0]?.id]);

  // Chat: poll online users every 10s
  useEffect(() => {
    if (!company?.id) return;
    const poll = () => api(`/api/messaging/online?companyId=${company.id}`).then(r => { if (r?.online) setChatOnlineUsers(r.online); });
    poll();
    const interval = setInterval(poll, 10000);
    return () => clearInterval(interval);
  }, [company?.id]);

  // Chat polling — 3s when on messages tab or floating chat open
  useEffect(() => {
    if ((!chatFloating && tab !== "messages") || !company?.id) return;
    const sender = collabs[0];
    const poll = () => {
      const latest = chatMessages.length ? chatMessages[chatMessages.length - 1].createdAt : "";
      if (!latest) return;
      const params = chatMode === "dm" && chatDmTarget
        ? `companyId=${company.id}&after=${encodeURIComponent(latest)}&senderId=${sender?.id}&recipientId=${chatDmTarget.id}`
        : `companyId=${company.id}&after=${encodeURIComponent(latest)}`;
      api(`/api/messaging?${params}`).then(r => {
        if (r?.messages?.length) {
          setChatMessages(prev => [...prev, ...r.messages]);
          setTimeout(() => chatEndRef.current?.scrollIntoView({ behavior: "smooth" }), 100);
        }
      });
    };
    const interval = setInterval(poll, 3000);
    return () => clearInterval(interval);
  }, [company?.id, tab, chatMessages.length, chatFloating, chatMode, chatDmTarget?.id]);

  // Chat: count unread when not on messages tab
  useEffect(() => {
    if (tab === "messages" || chatFloating) { setChatUnreadCount(0); return; }
    if (!company?.id) return;
    const check = () => {
      const latest = chatMessages.length ? chatMessages[chatMessages.length - 1].createdAt : "";
      if (latest) api(`/api/messaging?companyId=${company.id}&after=${encodeURIComponent(latest)}`).then(r => {
        if (r?.messages?.length) setChatUnreadCount(prev => prev + r.messages.length);
      });
    };
    const interval = setInterval(check, 5000);
    return () => clearInterval(interval);
  }, [tab, company?.id, chatFloating]);

  // Chat send handler — supports text, files, contact cards, voice notes
  const handleSendChat = (overrideType, overrideMsg, overrideAttachments) => {
    const sender = collabs[0];
    if (!sender || !company?.id) return;
    const type = overrideType || 'text';
    const msg = chatEditingMsg ? chatInput.trim() : (overrideMsg || (chatInput || '').trim());
    const atts = overrideAttachments || (chatFiles.length ? chatFiles : null);
    if (type === 'text' && !msg && !atts) return;

    // Edit mode
    if (chatEditingMsg) {
      api(`/api/messaging/${chatEditingMsg.id}`, { method: "PUT", body: { senderId: sender.id, message: msg } }).then(r => {
        if (r?.success) {
          setChatMessages(prev => prev.map(m => m.id === chatEditingMsg.id ? { ...m, message: msg, editedAt: r.editedAt } : m));
        }
      });
      setChatEditingMsg(null);
      setChatInput("");
      return;
    }

    const now = new Date().toISOString();
    const replyData = chatReplyTo ? { replyToId: chatReplyTo.id, replyToName: chatReplyTo.senderName, replyToMsg: (chatReplyTo.message || "").substring(0, 80) } : {};
    const recipientId = chatMode === "dm" && chatDmTarget ? chatDmTarget.id : null;
    setChatMessages(prev => [...prev, { id: "tmp_" + Date.now(), companyId: company.id, senderId: sender.id, senderName: sender.name, message: msg, attachments: atts, type, createdAt: now, recipientId, reactions: {}, ...replyData }]);
    if (!overrideType) { setChatInput(""); setChatFiles([]); setChatReplyTo(null); }
    setTimeout(() => chatEndRef.current?.scrollIntoView({ behavior: "smooth" }), 50);
    api("/api/messaging", { method: "POST", body: { companyId: company.id, senderId: sender.id, senderName: sender.name, message: msg, attachments: atts, type, recipientId, ...replyData } });
  };

  // Chat: delete message
  const handleDeleteChat = (msgId) => {
    const sender = collabs[0];
    if (!sender) return;
    api(`/api/messaging/${msgId}?senderId=${sender.id}`, { method: "DELETE" }).then(r => {
      if (r?.success) setChatMessages(prev => prev.filter(m => m.id !== msgId));
    });
    setChatContextMenu(null);
  };

  // Chat: add reaction
  const handleChatReaction = (msgId, emoji) => {
    const sender = collabs[0];
    if (!sender) return;
    api(`/api/messaging/${msgId}/reaction`, { method: "POST", body: { userId: sender.id, userName: sender.name, emoji } }).then(r => {
      if (r?.reactions) setChatMessages(prev => prev.map(m => m.id === msgId ? { ...m, reactions: r.reactions } : m));
    });
  };

  // Chat: handle file selection
  const handleChatFiles = (e) => {
    const files = Array.from(e.target.files).slice(0, 5);
    files.forEach(f => {
      if (f.size > 5 * 1024 * 1024) { pushNotification("Fichier trop volumineux", "Max 5 Mo par fichier", "danger"); return; }
      const reader = new FileReader();
      reader.onload = () => setChatFiles(prev => [...prev.slice(0, 4), { name: f.name, dataUrl: reader.result, size: f.size, type: f.type }]);
      reader.readAsDataURL(f);
    });
    if (chatFileRef.current) chatFileRef.current.value = '';
  };
  // Chat: paste image from clipboard (screenshots)
  const handleChatPaste = (e) => {
    const items = e.clipboardData?.items;
    if (!items) return;
    for (const item of items) {
      if (item.type.startsWith('image/')) {
        e.preventDefault();
        const file = item.getAsFile();
        if (!file || file.size > 5 * 1024 * 1024) return;
        const reader = new FileReader();
        reader.onload = () => setChatFiles(prev => [...prev.slice(0, 4), { name: 'capture_' + new Date().toLocaleTimeString('fr-FR', { hour: '2-digit', minute: '2-digit' }).replace(':', 'h') + '.png', dataUrl: reader.result, size: file.size, type: file.type }]);
        reader.readAsDataURL(file);
      }
    }
  };
  // Chat: share a contact card
  const handleShareContactCard = (ct) => {
    handleSendChat('contact_card', '', { name: ct.name, email: ct.email || '', phone: ct.phone || '', pipeline_stage: ct.pipeline_stage || 'nouveau', totalBookings: ct.totalBookings || 0, id: ct.id });
    setChatShowContactPicker(false);
  };
  // Chat: start voice recording
  const chatStartRecording = async () => {
    try {
      const stream = await navigator.mediaDevices.getUserMedia({ audio: true });
      const mediaRecorder = new MediaRecorder(stream);
      chatAudioChunksRef.current = [];
      mediaRecorder.ondataavailable = (e) => { if (e.data.size > 0) chatAudioChunksRef.current.push(e.data); };
      mediaRecorder.onstop = () => {
        const blob = new Blob(chatAudioChunksRef.current, { type: 'audio/webm' });
        const reader = new FileReader();
        reader.onload = () => {
          const dur = chatRecordingTime;
          handleSendChat('voice_note', '', { dataUrl: reader.result, type: 'audio/webm', name: `vocal_${new Date().toLocaleTimeString('fr-FR', { hour: '2-digit', minute: '2-digit' }).replace(':', 'h')}.webm`, size: blob.size, duration: dur });
        };
        reader.readAsDataURL(blob);
        stream.getTracks().forEach(t => t.stop());
      };
      chatMediaRecorderRef.current = mediaRecorder;
      mediaRecorder.start();
      setChatIsRecording(true);
      setChatRecordingTime(0);
      chatRecordingTimerRef.current = setInterval(() => setChatRecordingTime(p => p + 1), 1000);
    } catch (err) {
      pushNotification("Micro non disponible", "Autorisez l'accès au microphone", "danger");
    }
  };
  // Chat: stop voice recording
  const chatStopRecording = () => {
    if (chatMediaRecorderRef.current && chatIsRecording) {
      chatMediaRecorderRef.current.stop();
      setChatIsRecording(false);
      clearInterval(chatRecordingTimerRef.current);
    }
  };
  // Chat: cancel voice recording
  const chatCancelRecording = () => {
    if (chatMediaRecorderRef.current && chatIsRecording) {
      chatMediaRecorderRef.current.ondataavailable = null;
      chatMediaRecorderRef.current.onstop = null;
      chatMediaRecorderRef.current.stop();
      try { chatMediaRecorderRef.current.stream?.getTracks().forEach(t => t.stop()); } catch (e) {}
      setChatIsRecording(false);
      clearInterval(chatRecordingTimerRef.current);
      setChatRecordingTime(0);
    }
  };
  // Chat: group reactions for display
  const getChatReactions = (reactions) => {
    if (!reactions || typeof reactions !== 'object') return [];
    const grouped = {};
    Object.values(reactions).forEach(r => {
      if (!grouped[r.emoji]) grouped[r.emoji] = { emoji: r.emoji, users: [], isMine: false };
      grouped[r.emoji].users.push(r.userName);
      if (r.userId === collabs[0]?.id) grouped[r.emoji].isMine = true;
    });
    return Object.values(grouped);
  };
  // Auto-detection: set companyId for api() error tracking + JS error listeners
  useEffect(()=>{
    _autoTicketCompanyId = company?.id || null;
    const onError = (evtOrMsg, src, line, col, err) => {
      if (!company?.id) return;
      // Handle both ErrorEvent objects and legacy (msg, src, line, col, err) signatures
      let msg, stack;
      if (evtOrMsg instanceof ErrorEvent) {
        msg = evtOrMsg.message || 'Unknown error';
        stack = evtOrMsg.error?.stack || `${msg} at ${evtOrMsg.filename}:${evtOrMsg.lineno}:${evtOrMsg.colno}`;
      } else {
        msg = String(evtOrMsg || 'Unknown error');
        stack = err?.stack || `${msg} at ${src}:${line}:${col}`;
      }
      const env = collectEnv(); env.errorStack = stack;
      api('/api/tickets', { method:'POST', body:{ companyId:company.id, type:'auto_js_error', category:'bug', subject:`JS Error: ${msg.substring(0,80)}`, description:stack, environment_json:JSON.stringify(env) } });
    };
    const onRejection = (e) => {
      if (!company?.id) return;
      const env = collectEnv(); env.errorStack = e.reason?.stack || String(e.reason);
      api('/api/tickets', { method:'POST', body:{ companyId:company.id, type:'auto_js_error', category:'bug', subject:`Unhandled: ${String(e.reason).substring(0,80)}`, description:e.reason?.stack||String(e.reason), environment_json:JSON.stringify(env) } });
    };
    window.addEventListener('error', onError);
    window.addEventListener('unhandledrejection', onRejection);
    return () => { window.removeEventListener('error', onError); window.removeEventListener('unhandledrejection', onRejection); _autoTicketCompanyId = null; };
  },[company?.id]);
  // Online/offline connection indicator
  const [isOnline, setIsOnline] = useState(typeof navigator !== "undefined" ? navigator.onLine : true);
  useEffect(() => {
    const goOnline = () => setIsOnline(true);
    const goOffline = () => setIsOnline(false);
    window.addEventListener("online", goOnline);
    window.addEventListener("offline", goOffline);
    return () => { window.removeEventListener("online", goOnline); window.removeEventListener("offline", goOffline); };
  }, []);
  const [sidebarOpen, setSidebarOpen] = useState(false);
  const [navCatsOpen, setNavCatsOpen] = useState(() => { try { const s = localStorage.getItem("c360-nav-cats"); return s ? JSON.parse(s) : { planification:true, equipeCrm:true, leadsMgmt:true, communication:true, automatisation:false, contenu:false, systeme:false }; } catch { return { planification:true, equipeCrm:true, leadsMgmt:true, communication:true, automatisation:false, contenu:false, systeme:false }; } });
  const toggleNavCat = (cat) => setNavCatsOpen(prev => { const n = { ...prev, [cat]: !prev[cat] }; try { localStorage.setItem("c360-nav-cats", JSON.stringify(n)); } catch {} return n; });
  // Backup + Security dashboard
  const [backups, setBackups] = useState([]);
  const [backupLoading, setBackupLoading] = useState(false);
