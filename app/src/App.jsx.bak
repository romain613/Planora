  const [reminder1h, setReminder1h] = useState(false);
  const [reminder15min, setReminder15min] = useState(false);
  const [reminderSms, setReminderSms] = useState(false);
  const [settingsMaxAdvanceDays, setSettingsMaxAdvanceDays] = useState(60);
