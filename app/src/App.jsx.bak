    try { return JSON.parse(localStorage.getItem("calendar360-notifs") || "[]"); } catch { return []; }
  });
  const [notifPanelOpen, setNotifPanelOpen] = useState(false);
  const unreadCount = notifications.filter(n => !n.read).length;
