                      const dm=t.match(/le\s+(\d{1,2})\s+(janvier|fevrier|mars|avril|mai|juin|juillet|aout|septembre|octobre|novembre|decembre)/);
                      if(dm){date=`${new Date().getFullYear()}-${monthMap[dm[2]]}-${String(dm[1]).padStart(2,'0')}`;}
