  const [adminSmsMessages, setAdminSmsMessages] = useState([]);
  const [adminSmsCollabStats, setAdminSmsCollabStats] = useState(null);
  const [adminSmsLoading, setAdminSmsLoading] = useState(false);
  const [adminSmsPage, setAdminSmsPage] = useState(1);
  const [adminSmsTotalPages, setAdminSmsTotalPages] = useState(1);
  const [adminSmsTotal, setAdminSmsTotal] = useState(0);
  const [adminSmsFilterCollab, setAdminSmsFilterCollab] = useState('');
  const [adminSmsFilterFrom, setAdminSmsFilterFrom] = useState('');
  const [adminSmsFilterTo, setAdminSmsFilterTo] = useState('');
  const [adminSmsFilterStatus, setAdminSmsFilterStatus] = useState('');
  const [adminSmsSearch, setAdminSmsSearch] = useState('');
  const askConfirm = (title, message, onConfirm, danger = true) => setConfirmModal({ title, message, onConfirm, danger });
  const [workflows, setWorkflows] = useState(INIT_WORKFLOWS);
  const [editingWorkflow, setEditingWorkflow] = useState(null);
  const [notification, setNotification] = useState(null);
  // Chat / Messaging state
  const [chatMessages, setChatMessages] = useState([]);
  const [chatInput, setChatInput] = useState("");
  const [chatFiles, setChatFiles] = useState([]); // [{name, dataUrl, size, type}]
