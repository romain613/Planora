  const [agendaBookingDetailTab, setAgendaBookingDetailTab] = useState('rdv');
  const [agendaViewMode, _setAgendaViewMode] = useState(() => { try { return localStorage.getItem("c360-agendaViewMode") || "week"; } catch { return "week"; } });
  const setAgendaViewMode = (v) => { const val = typeof v === "function" ? v(agendaViewMode) : v; _setAgendaViewMode(val); localStorage.setItem("c360-agendaViewMode", val); };
  const [agendaMonthOffset, setAgendaMonthOffset] = useState(0);
