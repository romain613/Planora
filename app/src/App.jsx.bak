  const [chatContextMenu, setChatContextMenu] = useState(null); // {msgId, x, y}
  // Chat: voice recording
  const [chatIsRecording, setChatIsRecording] = useState(false);
  const [chatRecordingTime, setChatRecordingTime] = useState(0);
  const chatMediaRecorderRef = useRef(null);
  const chatAudioChunksRef = useRef([]);
  const chatRecordingTimerRef = useRef(null);
