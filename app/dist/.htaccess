RewriteEngine On

# Prevent caching of index.html (so new deployments are picked up immediately)
<Files "index.html">
  Header set Cache-Control "no-cache, no-store, must-revalidate"
  Header set Pragma "no-cache"
  Header set Expires "0"
</Files>

# Cache hashed assets (JS/CSS) for 1 year (filenames change on rebuild)
<FilesMatch "\.(js|css)$">
  Header set Cache-Control "public, max-age=31536000, immutable"
</FilesMatch>

# Proxy WebSocket for Twilio Media Streams (live transcription)
RewriteCond %{HTTP:Upgrade} websocket [NC]
RewriteCond %{HTTP:Connection} upgrade [NC]
RewriteRule ^media-stream(.*) ws://127.0.0.1:3001/media-stream$1 [P,L]

# Proxy API requests to Express
RewriteRule ^api/(.*) http://127.0.0.1:3001/api/$1 [P,L]

# Proxy Google OAuth callback to Express
RewriteRule ^auth/google/callback(.*) http://127.0.0.1:3001/auth/google/callback$1 [P,L]

# Proxy public landing pages to Express (server-rendered HTML + Tailwind)
RewriteRule ^page/(.*) http://127.0.0.1:3001/page/$1 [P,L]

# Proxy public booking pages to Express
RewriteRule ^book/(.*) http://127.0.0.1:3001/book/$1 [P,L]

# Proxy public forms to Express
RewriteRule ^form/(.*) http://127.0.0.1:3001/form/$1 [P,L]

# Serve static legal pages directly
RewriteRule ^privacy/?$ /privacy.html [L]
RewriteRule ^terms/?$ /terms.html [L]
RewriteRule ^mentions-legales/?$ /mentions-legales.html [L]

# SPA fallback: serve index.html for all other non-file routes
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule . /index.html [L]
