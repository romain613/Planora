# ─── Brevo (ex-Sendinblue) Configuration ───
# Obtenez votre clé API sur https://app.brevo.com/settings/keys/api
BREVO_API_KEY=

# Email expéditeur (doit être vérifié dans Brevo)
BREVO_SENDER_EMAIL=
BREVO_SENDER_NAME=

# SMS sender name (max 11 caractères, doit être validé par Brevo)
BREVO_SMS_SENDER=

# Server
PORT=

# Google Calendar OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=

# Outlook / Microsoft Graph OAuth (Phase 3) — fill in VPS .env only, never commit secret
OUTLOOK_CLIENT_ID=
OUTLOOK_CLIENT_SECRET=
OUTLOOK_REDIRECT_URI=
OUTLOOK_TENANT=common

# OpenAI API
OPENAI_API_KEY=

# Twilio VoIP
# Account SID & Auth Token (from https://console.twilio.com)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=

# Test credentials
TWILIO_TEST_ACCOUNT_SID=
TWILIO_TEST_AUTH_TOKEN=

# API Key + Secret for Access Token generation
# IMPORTANT: créer une API Key sur https://console.twilio.com/us1/account/keys-credentials/api-keys
TWILIO_API_KEY=
TWILIO_API_SECRET=

# TwiML App SID for marketplace mode (platform-level)
TWILIO_TWIML_APP_SID=

# Deepgram (Live Transcription STT)
# Get API key from https://console.deepgram.com
DEEPGRAM_API_KEY=

# App domain (used for WebSocket/webhook URLs)
APP_DOMAIN=

# DB path (monolithe officiel — cf. ecosystem.config.cjs en prod)
DB_PATH=
